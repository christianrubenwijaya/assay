{
  "name": "assay-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ASSAY -- automated judging harness for AI Pilot game-build competitions (BYOT). Public repo, free GitHub Actions.",
  "scripts": {
    "judge": "tsx src/cli.ts",
    "precheck": "tsx src/precheck/index.ts",
    "selftest": "tsx tests/selftest.ts",
    "test:unit": "tsx tests/aggregate.unit.ts && tsx tests/spearman.unit.ts && tsx tests/seed.unit.ts && tsx tests/elo.unit.ts",
    "spearman": "tsx tests/spearman.validate.ts",
    "assign-seeds": "tsx src/seed/cli.ts",
    "tournament": "tsx scripts/run_tournament.ts",
    "elo-round": "tsx scripts/run_elo_round.ts",
    "elo-apply": "tsx scripts/apply_round_results.ts",
    "verify-fixtures-jsdom": "node scripts/verify_fixtures_jsdom.mjs",
    "selftest:briefs": "tsx tests/dummy-briefs.local.ts"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.48.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}